{
  "name": "github-aws-runner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "^3.1020.0",
    "@aws-sdk/client-ec2": "^3.1020.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/client-ssm": "^3.1020.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "aws-cdk": "^2.188.0",
    "esbuild": "^0.25.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.188.0",
    "constructs": "^10.4.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
